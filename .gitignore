# 云信旺店单店版 .gitignore

# 依赖目录
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 运行时数据
*.log
*.pid
*.seed
*.pid.lock

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 环境变量
.env
.env.local

# 操作系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 临时文件
tmp/
temp/

# 生产环境备份文件
backup/
*.bak

# 单店版特定
database/shop.db
docs/nginx.conf.bak.*